# Copy to .env and adjust for your deployment.
# On the Ubuntu server set DJANGO_DEBUG=0 and a real SECRET_KEY / ALLOWED_HOSTS.

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
# Comma-separated origins for CSRF when behind nginx/https, e.g.
# DJANGO_CSRF_TRUSTED_ORIGINS=https://vpn.example.com

# --- WireGuard ---
WGPANEL_INTERFACE=wg0
WGPANEL_CONFIG_DIR=/etc/wireguard
WGPANEL_HELPER=/usr/local/sbin/wgpanel-helper
WGPANEL_USE_SUDO=1
# auto = Local backend on Linux, Fake backend elsewhere (Windows dev).
# Force with: local | fake
WGPANEL_BACKEND=auto
